<pre id="Gaussian_Elimination" style="display:hidden;">
 
    \begin{algorithm}
    \caption{Gaussian Elimination for Matrix Inversion}
    \begin{algorithmic}

    \INITIALIZE $m$ is arbitrary number
    \PROCEDURE{Forward-Substitution}{$i, m$}
        \FOR{$i = 1$ \TO $m$}
            \STATE Scale row to get pivot $1$
            \WHILE{$j &gt; i$}
                \STATE subtract multiple of row $i$ from row $j$ to zero out pivot column
                \STATE $n * \vec{i} $
            \ENDWHILE
        \ENDFOR
    \ENDPROCEDURE
    \PROCEDURE{Backward-Substitution}{$i, m$}
        \FOR{$i = m$ \TO $1$}  
            \STATE Scale row to get pivot $1$
            \WHILE{$j &lt; i$}
                \STATE zero out rest of column
                \STATE $n * \vec{i} $
            \ENDWHILE
        \ENDFOR
    \ENDPROCEDURE
    \end{algorithmic}
    \end{algorithm}
</pre>

